{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh 2>/dev/null"
  },
  "permissions": {
    "allow": [
      "Edit(.claude/skills/**)",
      "Write(.claude/skills/**)"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "{ test -x ./target/release/guard && ./target/release/guard edit; } || { test -x /workspace/target/release/guard && /workspace/target/release/guard edit; } || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{ test -x ./target/release/guard && ./target/release/guard bash; } || { test -x /workspace/target/release/guard && /workspace/target/release/guard bash; } || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./scripts/verify.sh"
          },
          {
            "type": "command",
            "command": "./crates/bizday/target/release/bizday lint --stdin 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}

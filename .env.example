# Copy this file to .env and fill in your values
# cp .env.example .env

# Anthropic API key for Claude Code
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optionally set Claude Code flags
# CLAUDE_CLI_FLAGS=

# Google OAuth2 Client ID (for browser-side auth)
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google Sheets API (you'll set these up later)
# GOOGLE_SHEETS_ID=your-spreadsheet-id
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# Collaboration relay server (local development)
# VITE_COLLAB_URL=ws://localhost:4000
# RELAY_HOST=0.0.0.0
# RELAY_PORT=4000
# RELAY_ALLOWED_ORIGINS=http://localhost:5173

# Collaboration relay server (Cloud Run production)
# VITE_COLLAB_URL=wss://your-relay-service-abc123-uc.a.run.app
